# =============================================================================
# .env.staging.example — Template de variables de entorno para staging
# =============================================================================
# NUNCA hardcodear valores reales. Usar Doppler para inyectar en runtime:
#   doppler run -- docker compose -f docker-compose.staging.yml up -d
#
# Copiar a .env.staging SOLO si no se usa Doppler (ej. CI sin Doppler setup).
# .env.staging está en .gitignore — jamás commitear con valores reales.
# =============================================================================

# --- Base de datos (Supabase remota) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (interno Docker) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Aplicación ---
SECRET_KEY=
ENV=staging
DEBUG=false
LOG_LEVEL=INFO

# --- Doppler (si se usa doppler run, este valor lo inyecta Doppler) ---
DOPPLER_TOKEN=

# --- Caddy / Dominio ---
STAGING_DOMAIN=staging.mt-pricing.com
CADDY_ACME_EMAIL=ops@br-innovation.com

# --- Frontend (Next.js) ---
NEXT_PUBLIC_BACKEND_URL=https://staging.mt-pricing.com
NEXTAUTH_URL=https://staging.mt-pricing.com
NEXTAUTH_SECRET=

# --- Supabase Storage ---
SUPABASE_STORAGE_BUCKET=product-images

# --- Hetzner (solo para scripts de infra, no para la app) ---
HCLOUD_TOKEN=

# --- Backblaze B2 (Terraform state) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Image tag (sobreescribir en deploy) ---
IMAGE_TAG=latest
