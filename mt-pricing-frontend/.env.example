# =============================================================================
# Frontend env vars — copia a .env.local y completá con valores reales
# =============================================================================
# Source de verdad: Supabase Dashboard > Project Settings > API
# Para obtener publishable_key:
#   https://supabase.com/dashboard/project/<project-ref>/settings/api
# =============================================================================

# Supabase (proyecto MT)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key (formato nuevo Supabase API v2 — RECOMENDADO).
# Empieza con `sb_publishable_`. Es público (safe en cliente).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Anon key (legacy — solo para retro-compat). Si usás publishable_key, dejá vacío.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend FastAPI (vía Caddy en deploy local con docker-compose).
# Local sin Caddy:    http://localhost:8000
# Local con Caddy:    http://localhost:${CADDY_HTTP_PORT}  (default 8080)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Sentry (opcional dev; obligatorio prod).
NEXT_PUBLIC_SENTRY_DSN=

# Idioma default de la UI (es | en).
NEXT_PUBLIC_DEFAULT_LOCALE=es
