{
  "name": "mt-pricing-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:install": "playwright install chromium",
    "validate:stack": "playwright test --config=tests/e2e/playwright.config.ts tests/e2e/01-healthchecks.spec.ts",
    "i18n:audit": "node scripts/i18n-audit.js",
    "openapi:gen": "bash scripts/openapi-gen.sh",
    "openapi:gen:static": "openapi-typescript ../_bmad-output/planning-artifacts/mt-api-contract-openapi.json -o lib/api/types.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
