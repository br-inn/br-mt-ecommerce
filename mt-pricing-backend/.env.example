# =============================================================================
# MT Middle East — MDM + Pricing — Backend env vars
# =============================================================================
# Copia a `.env` para dev local. NUNCA commits `.env`. En staging/prod los
# valores vienen de Doppler — este archivo es solo referencia.
#
# La BD vive en Supabase real (proyecto vayatmweveoaskyejzba). NO hay Postgres
# local. Las credenciales se obtienen del Supabase Dashboard:
#   https://supabase.com/dashboard/project/vayatmweveoaskyejzba/settings/api
#   https://supabase.com/dashboard/project/vayatmweveoaskyejzba/settings/database
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_NAME=mt-pricing-backend
APP_VERSION=0.1.0
ENV=development                          # development | staging | production
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
ENABLE_DOCS=true                         # /docs y /redoc — false en prod

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Supabase project --------------------------------------------------------
# Source: Settings > API
SUPABASE_URL=https://vayatmweveoaskyejzba.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_7tzfhep40mmdkETZlJGsSg_ODvuU43C
SUPABASE_ANON_KEY=                       # legacy — vacío si usás publishable_key

# Service role key — Settings > API > service_role secret.
# CRITICAL: NUNCA exponer al cliente — solo backend.
SUPABASE_SERVICE_ROLE_KEY=               # OBTENER DE Supabase Dashboard

# JWT secret — Settings > API > JWT Secret. Necesario para validar tokens.
SUPABASE_JWT_SECRET=                     # OBTENER DE Supabase Dashboard

# Storage buckets (deben existir en Supabase Storage).
SUPABASE_STORAGE_BUCKET_IMAGES=product-images
SUPABASE_STORAGE_BUCKET_DATASHEETS=product-datasheets
SUPABASE_STORAGE_BUCKET_IMPORTS=imports-raw
SUPABASE_STORAGE_BUCKET_EXPORTS=exports

# --- Database (Supabase Postgres) -------------------------------------------
# CONNECTION STRING: Settings > Database > Connection String > URI (pooler).
# - DATABASE_URL (asyncpg, runtime app)  → puerto 6543 (transaction pooler)
# - ALEMBIC_DATABASE_URL (psycopg, sync) → puerto 5432 (direct/session)
#
# Reemplazar [PASSWORD] con el password de la BD del Dashboard.
# Reemplazar la región (ej. eu-central-1) con la de tu proyecto.
DATABASE_URL=postgresql+asyncpg://postgres.vayatmweveoaskyejzba:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
ALEMBIC_DATABASE_URL=postgresql+psycopg://postgres.vayatmweveoaskyejzba:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_PRE_PING=true
DATABASE_ECHO=false

# --- Redis (dockerizado en el compose) ---------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Sentry (ADR-047) --------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# --- CORS --------------------------------------------------------------------
# Frontend Next.js + Caddy local. Ajustar puerto si cambiaste CADDY_HTTP_PORT.
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081","http://localhost:8080"]

# --- Observability (ADR-047) -------------------------------------------------
BETTER_STACK_LOGS_TOKEN=
BETTER_STACK_LOGS_HOST=
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# --- Auth / JWT --------------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Healthcheck auth (ADR-048) ---------------------------------------------
HEALTH_BASIC_AUTH_USER=monitoring
HEALTH_BASIC_AUTH_PASSWORD=change-me
HEALTH_TOKEN=

# --- External APIs (placeholders Fase 1.5+) ---------------------------------
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Timezone ----------------------------------------------------------------
TIMEZONE=Asia/Dubai

# --- Feature flags -----------------------------------------------------------
FEATURE_KB_ENABLED=false
FEATURE_COMPARATOR_ENABLED=false
FEATURE_OCR_ENABLED=false

# --- GraphRAG (Sprint 6 / Fase 1.5) -----------------------------------------
# Backend del graph store:
#   stub  → Neo4jStubGraphStore in-memory (default Fase 1)
#   neo4j → driver real contra Neo4j 5 (servicio `neo4j` del docker-compose)
#
# URI dentro del stack Docker: bolt://neo4j:7687 (nombre de servicio)
# URI desde el host (scripts, IDE): bolt://localhost:17687
GRAPHRAG_BACKEND=stub
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword
NEO4J_DATABASE=neo4j
NEO4J_CONNECTION_TIMEOUT_S=10.0
NEO4J_MAX_CONNECTION_POOL_SIZE=50

# --- Internal CDC webhook secret (US-F15-01-03) ---------------------------------
# Header X-Internal-Secret que Supabase Realtime envía al POST /internal/cdc/product.
# Vacío = endpoint abierto (solo en dev local). En staging/prod: string aleatorio > 32 chars.
INTERNAL_CDC_SECRET=

# --- Amazon SP API Competitor Fetcher (Fase 1.5) --------------------------------
# Credenciales para obtener precios de competidores en Amazon UAE.
# Distinto del adapter de publicación de precios (channel_mirror).
# MT_LIVE_NETWORK=true activa el adapter real; cualquier otro valor usa stub.
SP_API_REFRESH_TOKEN=
SP_API_LWA_CLIENT_ID=
SP_API_LWA_CLIENT_SECRET=
SP_API_SELLER_ID=
MT_LIVE_NETWORK=false

# --- VLM Judge (US-F15-02-02) -----------------------------------------------
# Activa ClaudeVlmJudgeAdapter (claude-sonnet-4-6) en el pipeline de comparación.
# Requiere ANTHROPIC_API_KEY válida.  false = NoopVlmJudgeAdapter (safe default).
VLM_JUDGE_ENABLED=false
ANTHROPIC_API_KEY=

# --- Reverse Image Search (US-F15-02-03) ------------------------------------
# Provider: tineye | google_lens_serpapi. Sin key válida → NoopRisAdapter.
REVERSE_IMAGE_PROVIDER=tineye
TINEYE_API_KEY=
SERPAPI_KEY=
REVERSE_IMAGE_DAILY_LIMIT=200
